  "buttons": {
    "primaryGradient": "linear-gradient(135deg, #7c3cff 0%, #2a0b57 100%)",
    "secondaryBg": "#ffffff",
    "minHeight": "52px",
    "fontWeight": "900"
  },
  "cards": {
    "background": "#ffffff",
    "border": "1px solid rgba(124, 60, 255, 0.18)",
    "shadow": "0 22px 60px rgba(33, 13, 75, 0.14)",
    "radius": "24px"
  },
  "surfaces": {
    "background": "#ffffff",
    "soft": "#fbf9ff",
    "dark": "#0b0716",
    "sectionSoftBg": "radial-gradient(circle at 50% 15%, rgba(124, 60, 255, 0.18), transparent 35%), linear-gradient(180deg, #ffffff, #fbf9ff)",
    "darkSectionBg": "radial-gradient(circle at 20% 25%, rgba(124, 60, 255, 0.28), transparent 35%), radial-gradient(circle at 90% 15%, rgba(184, 111, 255, 0.24), transparent 32%), linear-gradient(145deg, #171123, #080611)",
    "ctaBg": "radial-gradient(circle at 80% 30%, rgba(184, 111, 255, 0.55), transparent 32%), linear-gradient(135deg, #130920, #32106d)",
    "darkCardBg": "rgba(255, 255, 255, 0.08)",
    "darkCardBorder": "1px solid rgba(255, 255, 255, 0.13)",
