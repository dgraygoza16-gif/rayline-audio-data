{
  "brand": {
    "name": "Rayline Audio",
    "googleFontUrl": "https://fonts.googleapis.com/css2?family=Baloo+2:wght@500;700;800&display=swap",
    "fontPrimary": "'Baloo 2', 'Comic Sans MS', 'Comic Neue', Inter, Arial, sans-serif",
    "fontDisplay": "'Baloo 2', 'Comic Sans MS', 'Comic Neue', Inter, Arial, sans-serif"
  },
  "colors": {
    "primary": "#ffcc00",
    "primaryDark": "#ff8a00",
    "primarySoft": "#fff3b0",
    "accent": "#ff4fd8",
    "glow": "rgba(255, 174, 0, 0.36)",
    "black": "#1f1400",
    "body": "#332200",
    "muted": "#8a6a00",
    "white": "#ffffff",
    "pageSoft": "#fff8d6",
    "pageBg": "linear-gradient(180deg, #fffef2 0%, #fff4b8 48%, #ffffff 100%)",
    "darkBg": "#fff0a3",
    "darkBgSoft": "#ffd84d",
    "darkText": "#1f1400",
    "darkMuted": "#6f4c00"
  },
  "borders": {
    "default": "rgba(255, 178, 0, 0.32)",
    "strong": "rgba(255, 138, 0, 0.60)"
  },
  "shadows": {
    "card": "0 22px 60px rgba(255, 174, 0, 0.22)",
    "button": "0 18px 38px rgba(255, 174, 0, 0.35)",
    "soft": "0 14px 34px rgba(255, 174, 0, 0.18)",
    "dark": "0 34px 90px rgba(255, 174, 0, 0.28)"
  },
  "radius": {
    "small": "18px",
    "medium": "22px",
    "large": "28px",
    "xl": "34px",
    "pill": "999px"
  },
  "buttons": {
    "primaryGradient": "linear-gradient(135deg, #ffcc00 0%, #ff8a00 100%)",
    "secondaryBg": "#ffffff",
    "minHeight": "54px",
    "fontWeight": "950"
  },
  "cards": {
    "background": "#ffffff",
    "border": "1px solid rgba(255, 178, 0, 0.32)",
    "shadow": "0 22px 60px rgba(255, 174, 0, 0.22)",
    "radius": "28px"
  },
  "surfaces": {
    "background": "#ffffff",
    "soft": "#fff8d6",
    "dark": "#ffd84d",
    "sectionSoftBg": "radial-gradient(circle at 50% 15%, rgba(255, 204, 0, 0.24), transparent 35%), linear-gradient(180deg, #ffffff, #fff8d6)",
    "darkSectionBg": "radial-gradient(circle at 18% 18%, rgba(255, 79, 216, 0.25), transparent 34%), radial-gradient(circle at 92% 18%, rgba(255, 204, 0, 0.42), transparent 34%), linear-gradient(145deg, #fff0a3, #ffd84d)",
    "ctaBg": "radial-gradient(circle at 80% 30%, rgba(255, 79, 216, 0.30), transparent 32%), linear-gradient(135deg, #fff0a3, #ffcc00)",
    "darkCardBg": "rgba(255, 255, 255, 0.48)",
    "darkCardBorder": "1px solid rgba(255, 138, 0, 0.36)",
    "darkPillBg": "rgba(255, 255, 255, 0.55)"
  },
  "effects": {
    "primaryWash": "rgba(255, 204, 0, 0.30)",
    "primaryWashStrong": "rgba(255, 204, 0, 0.45)",
    "accentWash": "rgba(255, 79, 216, 0.25)",
    "glowSoft": "rgba(255, 204, 0, 0.22)",
    "glowMedium": "rgba(255, 174, 0, 0.35)",
    "darkGlow": "rgba(255, 174, 0, 0.28)",
    "lightOverlay": "rgba(255, 255, 255, 0.48)",
    "lightOverlayStrong": "rgba(255, 255, 255, 0.62)",
    "lightBorder": "rgba(255, 138, 0, 0.28)",
    "lightBorderStrong": "rgba(255, 138, 0, 0.42)"
