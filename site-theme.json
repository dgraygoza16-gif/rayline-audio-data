    "black": "#090713",
    "body": "#151225",
    "muted": "#6d647d",
    "white": "#ffffff",
    "pageSoft": "#fbf9ff",
    "pageBg": "linear-gradient(180deg, #ffffff 0%, #fbf9ff 48%, #ffffff 100%)",
    "darkBg": "#0b0716",
    "darkBgSoft": "#150929",
    "darkText": "#ffffff",
    "darkMuted": "#cfc3e9"
  },
  "borders": {
    "default": "rgba(124, 60, 255, 0.18)",
    "strong": "rgba(124, 60, 255, 0.34)"
