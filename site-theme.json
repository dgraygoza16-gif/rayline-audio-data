{
  "brand": {
    "name": "Rayline Audio",
    "googleFontUrl": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900;950&display=swap",
    "fontPrimary": "Inter, Arial, sans-serif",
    "fontDisplay": "Inter, Arial, sans-serif"
  },
  "colors": {
    "primary": "#7c3cff",
    "primaryDark": "#2a0b57",
    "primarySoft": "#efe7ff",
    "accent": "#b66cff",
