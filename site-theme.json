  "effects": {
    "primaryWash": "rgba(124, 60, 255, 0.12)",
    "primaryWashStrong": "rgba(124, 60, 255, 0.22)",
    "accentWash": "rgba(184, 111, 255, 0.24)",
    "glowSoft": "rgba(124, 60, 255, 0.14)",
    "glowMedium": "rgba(124, 60, 255, 0.35)",
    "darkGlow": "rgba(42, 11, 87, 0.32)",
    "lightOverlay": "rgba(255, 255, 255, 0.08)",
