    const raLoginTab = document.getElementById("raLoginTab");
    const raAuthForm = document.getElementById("raAuthForm");
    const raUsernameGroup = document.getElementById("raUsernameGroup");
    const raUsernameInput = document.getElementById("raUsername");
    const raEmailInput = document.getElementById("raEmail");
    const raPasswordInput = document.getElementById("raPassword");
    const raSubmitBtn = document.getElementById("raSubmitBtn");
    const raMessageBox = document.getElementById("raAuthMessage");
    const raAccountBox = document.getElementById("raAccountBox");
    const raAccountName = document.getElementById("raAccountName");
    const raAccountAvatar = document.getElementById("raAccountAvatar");
    const raUserEmail = document.getElementById("raUserEmail");
    const raLogoutBtn = document.getElementById("raLogoutBtn");
    const raCreditBalance = document.getElementById("raCreditBalance");
    const raSubStatus = document.getElementById("raSubStatus");
    const raAuthOpenBtn = document.getElementById("raAuthOpenBtn");
    const raAuthModal = document.getElementById("raAuthModal");
    const raAuthBackdrop = document.getElementById("raAuthBackdrop");
    const raAuthCloseBtn = document.getElementById("raAuthCloseBtn");
    const raAuthCard = document.querySelector(".ra-auth-modal-card");
    const raSubscribeTriggers = document.querySelectorAll(".ra-subscribe-trigger");
    const raSubscribeMsg = document.getElementById("raSubscribeMsg");

    function raNormalizeUsername(username) {
      return String(username || "")
        .trim()
        .toLowerCase()
        .replace(/\s+/g, "_")
        .replace(/[^a-z0-9_]/g, "")
        .slice(0, 24);
    }

    function raOpenAuthModal(mode) {
      if (mode) raSetAuthMode(mode);
      if (!raAuthModal) return;
      raAuthModal.classList.add("ra-open");
      raAuthModal.setAttribute("aria-hidden", "false");
      document.documentElement.style.overflow = "hidden";
    }

    function raCloseAuthModal() {
      if (!raAuthModal) return;
      raAuthModal.classList.remove("ra-open");
      raAuthModal.setAttribute("aria-hidden", "true");
      document.documentElement.style.overflow = "";
    }

    function raShowAuthMessage(text) {
      if (!raMessageBox) return;
      raMessageBox.style.display = "block";
      raMessageBox.textContent = text;
    }

    function raShowSubscribeMessage(text) {
      if (!raSubscribeMsg) return;
      raSubscribeMsg.style.display = "block";
      raSubscribeMsg.textContent = text;
    }

    window.raGetSession = async function () {
      const { data } = await raSupabase.auth.getSession();
      return data.session || null;
    };

    async function raStartSubscription() {
      raShowSubscribeMessage("Checking your account...");

      raSubscribeTriggers.forEach(function (button) {
        button.disabled = true;
        button.dataset.originalText = button.textContent.trim();
        button.textContent = "Loading...";
      });

      try {
        const session = await window.raGetSession();

        if (!session) {
          raShowSubscribeMessage("Please sign up or log in before subscribing.");
          raOpenAuthModal("login");
          return;
        }

        const response = await fetch("https://mpsjbhzwdbtsiklnkoya.supabase.co/functions/v1/create_checkout_sessions", {
          method: "POST",
          mode: "cors",
          headers: {
            "Content-Type": "application/json",
            "Authorization": "Bearer " + session.access_token,
            "apikey": raSupabaseAnonKey
          }
        });

        const data = await response.json();

        if (!response.ok) {
          throw new Error(data.error || "Could not start checkout.");
        }

        window.top.location.href = data.url;
      } catch (error) {
        console.error("Rayline subscription error:", error);
        raShowSubscribeMessage(error.message || "Something went wrong.");
      } finally {
        raSubscribeTriggers.forEach(function (button) {
          button.disabled = false;
          button.textContent = button.dataset.originalText || "Subscribe & Get 100 Credits";
        });
      }
    }

    function raSetAuthMode(mode) {
      raAuthMode = mode;

      if (mode === "signup") {
        raSignupTab.classList.add("ra-active");
        raLoginTab.classList.remove("ra-active");
        raSubmitBtn.textContent = "Create Account";
        raPasswordInput.placeholder = "Create a password";
        raPasswordInput.autocomplete = "new-password";

        if (raUsernameGroup) raUsernameGroup.style.display = "grid";
        if (raUsernameInput) raUsernameInput.required = true;
      } else {
        raLoginTab.classList.add("ra-active");
        raSignupTab.classList.remove("ra-active");
        raSubmitBtn.textContent = "Log In";
        raPasswordInput.placeholder = "Enter your password";
        raPasswordInput.autocomplete = "current-password";

        if (raUsernameGroup) raUsernameGroup.style.display = "none";
        if (raUsernameInput) raUsernameInput.required = false;
      }

      if (raMessageBox) raMessageBox.style.display = "none";
    }

    function raGetDisplayName(user, profile) {
      const metadataName = user && user.user_metadata
        ? (user.user_metadata.username || user.user_metadata.display_name || user.user_metadata.name)
        : "";

      const profileName = profile && profile.username ? profile.username : "";
      const fallback = user && user.email ? user.email.split("@")[0] : "Rayline Audio Account";

      return String(profileName || metadataName || fallback).trim();
    }

    function raUpdateAccountIdentity(user, profile) {
      const displayName = raGetDisplayName(user, profile);
      const email = user && user.email ? user.email : "";

      if (raAccountName) raAccountName.textContent = displayName;
      if (raUserEmail) raUserEmail.textContent = email;
      if (raAccountAvatar) raAccountAvatar.textContent = displayName.charAt(0).toUpperCase() || "R";

      if (raAuthOpenBtn) {
        raAuthOpenBtn.textContent = displayName || "Account";
      }
    }

    async function raSaveSignupProfile(user, username) {
      if (!user || !username) return;

      const profilePayload = {
        id: user.id,
        email: user.email || "",
        username: username,
        subscription_status: "free"
      };

      try {
        const { error: updateError } = await raSupabase
          .from("profiles")
          .update({
            email: profilePayload.email,
            username: profilePayload.username,
            subscription_status: profilePayload.subscription_status
          })
          .eq("id", user.id);

        if (updateError) {
          await raSupabase
            .from("profiles")
            .upsert({
              ...profilePayload,
              credits: 20
            }, { onConflict: "id" });
        }
      } catch (error) {
        console.warn("Rayline Audio profile save skipped:", error);
      }
    }

    async function raLoadProfile(user) {
      if (!user) return;

      const profileResult = await raSupabase
        .from("profiles")
        .select("username, email, credits, subscription_status")
        .eq("id", user.id)
        .single();

      const profile = profileResult.error ? null : profileResult.data;

      raUpdateAccountIdentity(user, profile);

      if (!profile) {
        if (raCreditBalance) raCreditBalance.textContent = "Not set up yet";
        if (raSubStatus) raSubStatus.textContent = "Free";
        return;
      }

      if (raCreditBalance) raCreditBalance.textContent = profile.credits ?? 0;
      if (raSubStatus) raSubStatus.textContent = profile.subscription_status || "free";
    }

    async function raCheckSession() {
      const { data } = await raSupabase.auth.getSession();
      const session = data.session;

      if (session && session.user) {
        if (raAuthForm) raAuthForm.style.display = "none";
        if (raAccountBox) raAccountBox.style.display = "block";
        if (raAuthCard) raAuthCard.classList.add("ra-account-active");
        if (raAuthOpenBtn) raAuthOpenBtn.classList.add("ra-logged-in");

        await raLoadProfile(session.user);
      } else {
        if (raAuthForm) raAuthForm.style.display = "grid";
        if (raAccountBox) raAccountBox.style.display = "none";
        if (raAccountName) raAccountName.textContent = "Rayline Audio Account";
        if (raUserEmail) raUserEmail.textContent = "";
        if (raAuthCard) raAuthCard.classList.remove("ra-account-active");

        if (raAuthOpenBtn) {
          raAuthOpenBtn.textContent = "Sign Up / Log In";
          raAuthOpenBtn.classList.remove("ra-logged-in");
        }

        raSetAuthMode(raAuthMode || "signup");
      }
    }

    if (raSubscribeTriggers.length) {
      raSubscribeTriggers.forEach(function (button) {
        button.addEventListener("click", raStartSubscription);
      });
    }

    if (raAuthOpenBtn) {
      raAuthOpenBtn.addEventListener("click", function () {
        raOpenAuthModal();
      });
    }

    if (raAuthBackdrop) {
      raAuthBackdrop.addEventListener("click", raCloseAuthModal);
    }

    if (raAuthCloseBtn) {
      raAuthCloseBtn.addEventListener("click", raCloseAuthModal);
    }

    document.addEventListener("keydown", function (event) {
      if (event.key === "Escape") raCloseAuthModal();
    });

    if (raSignupTab && raLoginTab && raAuthForm) {
      raSignupTab.addEventListener("click", () => raSetAuthMode("signup"));
      raLoginTab.addEventListener("click", () => raSetAuthMode("login"));

      raAuthForm.addEventListener("submit", async (event) => {
        event.preventDefault();

        const email = raEmailInput.value.trim().toLowerCase();
        const password = raPasswordInput.value;
        const username = raNormalizeUsername(raUsernameInput ? raUsernameInput.value : "");

        if (raAuthMode === "signup") {
          if (!username) {
            raShowAuthMessage("Choose a username before creating your account.");
            return;
          }

          if (username.length < 3) {
            raShowAuthMessage("Username must be at least 3 characters.");
            return;
          }

          if (!/^[a-z0-9_]+$/.test(username)) {
            raShowAuthMessage("Usernames can only use letters, numbers, and underscores.");
            return;
          }
        }

        raSubmitBtn.disabled = true;
        raSubmitBtn.textContent = raAuthMode === "signup" ? "Creating..." : "Logging in...";

        try {
          if (raAuthMode === "signup") {
            const { data, error } = await raSupabase.auth.signUp({
              email,
              password,
              options: {
                data: {
                  username: username,
                  display_name: username
                }
              }
            });

            if (error) throw error;

            if (data && data.user) {
              await raSaveSignupProfile(data.user, username);
            }

            if (data && data.session) {
              raShowAuthMessage("Account created successfully. You are now logged in.");
              await raCheckSession();
            } else {
              raShowAuthMessage("Account created. Check your email to confirm your account, then log in.");
            }
          } else {
            const { error } = await raSupabase.auth.signInWithPassword({
              email,
              password
            });

            if (error) throw error;

            raShowAuthMessage("Logged in successfully.");
            await raCheckSession();
          }
        } catch (error) {
          const errorMessage = error && error.message ? error.message : "Something went wrong.";

          if (errorMessage.toLowerCase().includes("duplicate") || errorMessage.toLowerCase().includes("unique")) {
            raShowAuthMessage("That username is already taken. Choose another one.");
          } else {
            raShowAuthMessage(errorMessage);
          }
        }

        raSubmitBtn.disabled = false;
        raSubmitBtn.textContent = raAuthMode === "signup" ? "Create Account" : "Log In";
      });
    }

    if (raLogoutBtn) {
      raLogoutBtn.addEventListener("click", async () => {
        await raSupabase.auth.signOut();
        raShowAuthMessage("Logged out.");
        await raCheckSession();
      });
    }

    raSupabase.auth.onAuthStateChange(function () {
      raCheckSession();
    });

    raSetAuthMode("signup");
    await raCheckSession();
  </script>

</section>
