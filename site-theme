  <script>
    const raBeatDatabaseUrl = "https://raw.githubusercontent.com/dgraygoza16-gif/rayline-audio-data/refs/heads/main/beats-data.json";
    // Global design/theme data loads from raSiteThemeUrl above: site-theme.json

    let raBeats = [];

    const raAudio = document.getElementById("raFeaturedAudio");
    const raFeaturedPlay = document.getElementById("raFeaturedPlay");
    const raFeaturedWave = document.getElementById("raFeaturedWave");
    const raFeaturedWaveArea = document.getElementById("raFeaturedWaveArea");
    const raCurrentTime = document.getElementById("raCurrentTime");
    const raDuration = document.getElementById("raDuration");
    const raAudioSlider = document.getElementById("raAudioSlider");

    if (raFeaturedWave && !raFeaturedWave.children.length) {
      for (let i = 0; i < 76; i++) {
        raFeaturedWave.appendChild(document.createElement("span"));
      }
    }

    function raFormatTime(seconds) {
      if (!seconds || isNaN(seconds)) return "0:00";
      const minutes = Math.floor(seconds / 60);
      const remainingSeconds = Math.floor(seconds % 60).toString().padStart(2, "0");
      return minutes + ":" + remainingSeconds;
    }

    function raGetStartingPrice(beat) {
      if (!beat.prices) return "$9.99";
      return beat.prices.basic || beat.prices.Basic || Object.values(beat.prices)[0] || "$9.99";
    }

    function raHexToRgba(hex, alpha) {
      if (!hex || typeof hex !== "string") return "rgba(124, 60, 255, " + alpha + ")";

      let clean = hex.replace("#", "").trim();

      if (clean.length === 3) {
        clean = clean.split("").map(char => char + char).join("");
      }

      if (clean.length !== 6) return "rgba(124, 60, 255, " + alpha + ")";

      const r = parseInt(clean.substring(0, 2), 16);
      const g = parseInt(clean.substring(2, 4), 16);
      const b = parseInt(clean.substring(4, 6), 16);

      return "rgba(" + r + ", " + g + ", " + b + ", " + alpha + ")";
    }

    function raGetBeatTheme(beat) {
      const theme = beat.theme || {};
      const primary = theme.primary || "#7c3cff";
      const secondary = theme.secondary || "#2a0b57";
      const soft = theme.soft || "#efe7ff";
      const accent = theme.accent || primary;

      return {
        primary: primary,
        secondary: secondary,
        soft: soft,
        accent: accent,
        border: raHexToRgba(primary, 0.22),
        shadow: theme.shadow || raHexToRgba(primary, 0.16),
        gradient: theme.gradient || "linear-gradient(135deg, " + primary + " 0%, " + accent + " 100%)",
        playerGradient: theme.playerGradient || "linear-gradient(135deg, " + secondary + " 0%, " + (theme.dark || "#090713") + " 100%)"
      };
    }

    function raGetBeatThemeStyle(beat) {
      const theme = raGetBeatTheme(beat);

      return [
        "--beat-primary:" + theme.primary,
        "--beat-secondary:" + theme.secondary,
        "--beat-soft:" + theme.soft,
        "--beat-border:" + theme.border,
        "--beat-shadow:" + theme.shadow,
        "--beat-gradient:" + theme.gradient
      ].join(";");
    }

    function raApplyFeaturedTheme(beat) {
      const player = document.querySelector(".ra-featured-player");
      if (!player) return;

      const theme = raGetBeatTheme(beat);

      player.classList.remove("ra-theme-switching");
      void player.offsetWidth;

      player.style.setProperty("--featured-primary", theme.primary);
      player.style.setProperty("--featured-secondary", theme.secondary);
      player.style.setProperty("--featured-soft", theme.soft);
      player.style.setProperty("--featured-accent", theme.accent);
      player.style.setProperty("--featured-gradient", theme.gradient);
      player.style.setProperty("--featured-player-gradient", theme.playerGradient);
      player.style.setProperty("--featured-shadow", theme.shadow);
      player.style.setProperty("--featured-border", theme.border);
      player.style.setProperty("--featured-cover-glow", raHexToRgba(theme.primary, 0.22));

      player.classList.add("ra-theme-switching");

      window.clearTimeout(player.raThemeTimer);
      player.raThemeTimer = window.setTimeout(function () {
        player.classList.remove("ra-theme-switching");
      }, 720);
    }

    function raTogglePlayer() {
      if (!raAudio.src) return;

      if (raAudio.paused) {
        raAudio.play();
      } else {
        raAudio.pause();
      }

      raUpdateButtons();
    }

    function raUpdateButtons() {
      const isPlaying = !raAudio.paused;
      if (raFeaturedPlay) {
        raFeaturedPlay.classList.toggle("ra-playing", isPlaying);
        raFeaturedPlay.setAttribute("aria-label", isPlaying ? "Pause featured beat" : "Play featured beat");
      }
    }

    function raUpdateWaveformProgress() {
      if (!raFeaturedWave) return;

      const bars = raFeaturedWave.querySelectorAll("span");
      const progress = raAudio.duration ? raAudio.currentTime / raAudio.duration : 0;

      if (raAudioSlider && !raAudioSlider.matches(":active")) {
        raAudioSlider.value = raAudio.duration ? raAudio.currentTime : 0;
      }

      bars.forEach(function (bar, index) {
        const barProgress = bars.length > 1 ? index / (bars.length - 1) : 0;

        if (barProgress <= progress) {
          bar.style.opacity = "1";
          bar.style.background = "linear-gradient(180deg, #ffffff 0%, var(--featured-soft) 100%)";
        } else {
          bar.style.opacity = "0.52";
          bar.style.background = "linear-gradient(180deg, #ffffff 0%, var(--featured-soft) 100%)";
        }
      });
    }

    function raSetElementText(id, value) {
      const element = document.getElementById(id);
      if (element) element.textContent = value;
    }

    function raSetElementHtml(id, value) {
      const element = document.getElementById(id);
      if (element) element.innerHTML = value;
    }

    function raRenderFeaturedBeat(beat) {
      const beatUrl = beat.url || `https://www.raylineaudio.com/${beat.slug}`;

      raApplyFeaturedTheme(beat);

      raSetElementText("raFeaturedTitle", beat.title || "Featured Beat");

      const featuredCover = document.getElementById("raFeaturedCover");
      if (featuredCover) featuredCover.style.backgroundImage = `url("${beat.image}")`;

      const miniCover = document.getElementById("raMiniCover");
      if (miniCover) miniCover.style.backgroundImage = `url("${beat.image}")`;

      const featuredCoverLink = document.getElementById("raFeaturedCoverLink");
      if (featuredCoverLink) featuredCoverLink.href = beatUrl;

      raSetElementText("raFeaturedPrice", raGetStartingPrice(beat));

      const featuredBuy = document.getElementById("raFeaturedBuy");
      if (featuredBuy) featuredBuy.href = beatUrl;

      raSetElementText("raFeaturedBpm", beat.bpm || "—");
      raSetElementText("raFeaturedKey", beat.key || "—");
      raSetElementText("raFeaturedGenre", beat.genre || "—");

      if (raAudio) {
        raAudio.src = beat.audio || "";
        raAudio.load();
      }

      if (raCurrentTime) raCurrentTime.textContent = "0:00";
      if (raDuration) raDuration.textContent = "0:00";

      if (raAudioSlider) {
        raAudioSlider.value = 0;
        raAudioSlider.max = 100;
      }

      raUpdateWaveformProgress();
      raUpdateButtons();

      raSetElementHtml("raFeaturedMeta", `
        <span>▦ ${beat.bpm || "—"} BPM</span>
        <span>♫ ${beat.key || "—"}</span>
        <span>♥ ${beat.genre || "—"}</span>
      `);

      raSetElementHtml("raFeaturedTags", (beat.tags || [])
        .slice(0, 3)
        .map(tag => `<span class="ra-tag">#${String(tag).replace("#", "")}</span>`)
        .join(""));
    }

    function raRenderBeatCards(beats) {
      document.getElementById("raFeaturedBeatsGrid").innerHTML = beats.map(beat => {
        const tags = beat.genre || "";

        return `
          <a href="${beat.url || `https://www.raylineaudio.com/${beat.slug}`}" target="_top" class="ra-beat-card" style="${raGetBeatThemeStyle(beat)}">
            <div class="ra-beat-art" style="--art:url('${beat.image}')">
              <button class="ra-heart" type="button">♡</button>
              <button class="ra-card-play" type="button" onclick="event.preventDefault(); raPlayBeat('${beat.id}')">▶</button>
            </div>
            <div class="ra-beat-info">
              <h3>${beat.title}</h3>
              <div class="ra-beat-line">${tags} • ${beat.bpm || "-"} BPM</div>
              <div class="ra-beat-price">${raGetStartingPrice(beat)}+</div>
            </div>
          </a>
        `;
      }).join("");
    }

    function raRenderGenres(beats) {
      const genres = [...new Set(beats.map(beat => beat.genre).filter(Boolean))];

      document.getElementById("raGenreGrid").innerHTML = genres.map(genre => `
        <a class="ra-genre-card" href="https://www.raylineaudio.com/beats" target="_top">
          <strong>${genre}</strong>
          <span>Browse ${genre} beats</span>
        </a>
      `).join("");
    }

    function raRenderNewReleases(beats) {
      const sorted = [...beats].sort((a, b) => new Date(b.dateAdded) - new Date(a.dateAdded));

      document.getElementById("raNewReleasesGrid").innerHTML = sorted.map(beat => `
        <a class="ra-release" style="${raGetBeatThemeStyle(beat)}" href="${beat.url || `https://www.raylineaudio.com/${beat.slug}`}" target="_top">
          <div class="ra-release-art" style="background-image:url('${beat.image}')"></div>
          <div>
            <h3>${beat.title}</h3>
            <p>${beat.bpm || "-"} BPM • ${beat.key || "-"} • ${beat.genre || "-"}</p>
          </div>
        </a>
      `).join("");
    }

    function raRenderLicenses(beat) {
      const prices = beat.prices || {};
      const bullets = beat.licenseBullets || {};

      const licenses = [
        {
          name: "Basic License",
          price: prices.basic || prices.Basic || "$9.99",
          bullets: bullets.basic || bullets.Basic || ["MP3 Untagged", "Commercial Use", "Up to 10,000 Streams", "Non-exclusive"],
          url: "https://www.raylineaudio.com/about",
          featured: false
        },
        {
          name: "Premium License",
          price: prices.premium || prices.Premium || "$19.99",
          bullets: bullets.premium || bullets.Premium || ["MP3 + WAV Files", "Stem Trackouts", "Higher Stream Limit", "Non-exclusive"],
          url: "https://www.raylineaudio.com/about",
          featured: true
        },
        {
          name: "Exclusive License",
          price: prices.exclusive || prices.Exclusive || "Contact",
          bullets: bullets.exclusive || bullets.Exclusive || ["All Rights Included", "Unlimited Sales", "Unlimited Streams", "Beat Removed from Store"],
          url: "https://www.raylineaudio.com/contact",
          featured: false
        }
      ];

      document.getElementById("raLicenseGrid").innerHTML = licenses.map(license => `
        <div class="ra-license-card ${license.featured ? "featured" : ""}">
          ${license.featured ? `<div class="ra-popular">MOST POPULAR</div>` : ""}
          <h3>${license.name}</h3>
          <p>${license.name === "Exclusive License" ? "Own the beat forever and remove it from the public store." : "View full license details before purchasing."}</p>
          <ul>${license.bullets.map(item => `<li>${item}</li>`).join("")}</ul>
          <div class="ra-license-price">${license.price}</div>
          <a href="${license.url}" target="_top" class="ra-btn ${license.featured ? "ra-btn-primary" : "ra-btn-secondary"}">
            ${license.name === "Exclusive License" ? "Contact for Exclusive" : "View Tier Details"}
          </a>
        </div>
      `).join("");
    }

    function raPlayBeat(beatId) {
      const beat = raBeats.find(item => item.id === beatId);
      if (!beat) return;

      raRenderFeaturedBeat(beat);
      raAudio.play();
      raUpdateButtons();
    }

    async function raLoadHomePageBeats() {
      try {
        const response = await fetch(raBeatDatabaseUrl);
        const data = await response.json();

        raBeats = Array.isArray(data) ? data : data.beats || [];
        raBeats = raBeats.filter(beat => beat.isAvailable !== false);

        const featured = raBeats.find(beat => beat.isFeatured) || raBeats[0];

        if (!featured) return;

        raRenderFeaturedBeat(featured);
        raRenderBeatCards(raBeats);
        raRenderGenres(raBeats);
        raRenderNewReleases(raBeats);
        raRenderLicenses(featured);
      } catch (error) {
        console.error("Rayline Audio database failed to load:", error);
      }
    }

    function raSeekFeaturedWave(event) {
      if (!raAudio.duration || isNaN(raAudio.duration) || !raFeaturedWave) return;

      const rect = raFeaturedWave.getBoundingClientRect();
      const clickPosition = event.clientX - rect.left;
      let percentage = clickPosition / rect.width;

      percentage = Math.max(0, Math.min(1, percentage));
      raAudio.currentTime = raAudio.duration * percentage;
      if (raCurrentTime) raCurrentTime.textContent = raFormatTime(raAudio.currentTime);
      raUpdateWaveformProgress();

      if (raAudio.paused) {
        raAudio.play();
      }
    }


    function raSeekFromBottomSlider() {
      if (!raAudioSlider || !raAudio.duration || isNaN(raAudio.duration)) return;

      const newTime = Math.max(0, Math.min(Number(raAudioSlider.value) || 0, raAudio.duration));
      raAudio.currentTime = newTime;
      if (raCurrentTime) raCurrentTime.textContent = raFormatTime(newTime);
      raUpdateWaveformProgress();
    }

    if (raAudioSlider) {
      raAudioSlider.addEventListener("input", function () {
        if (!raAudio.duration || isNaN(raAudio.duration)) return;

        const previewTime = Math.max(0, Math.min(Number(raAudioSlider.value) || 0, raAudio.duration));
        raAudio.currentTime = previewTime;
        if (raCurrentTime) raCurrentTime.textContent = raFormatTime(previewTime);
        raUpdateWaveformProgress();
      });

      raAudioSlider.addEventListener("change", raSeekFromBottomSlider);
    }
    if (raFeaturedWave) {
      raFeaturedWave.addEventListener("click", raSeekFeaturedWave);
    }

    raAudio.addEventListener("loadedmetadata", function () {
      if (raDuration) raDuration.textContent = raFormatTime(raAudio.duration);

      if (raAudioSlider && raAudio.duration && !isNaN(raAudio.duration)) {
        raAudioSlider.max = raAudio.duration;
        raAudioSlider.value = raAudio.currentTime || 0;
      }

      raUpdateWaveformProgress();
    });

    raAudio.addEventListener("timeupdate", function () {
      if (raCurrentTime) raCurrentTime.textContent = raFormatTime(raAudio.currentTime);
      if (raDuration) raDuration.textContent = raFormatTime(raAudio.duration);
      raUpdateWaveformProgress();
    });

    raAudio.addEventListener("play", raUpdateButtons);
    raAudio.addEventListener("pause", raUpdateButtons);
    raAudio.addEventListener("ended", function () {
      raUpdateButtons();
      raUpdateWaveformProgress();
    });

    raLoadHomePageBeats();
  </script>

  <script type="module">
