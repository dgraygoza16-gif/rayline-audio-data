<section class="ra-homepage">

  <script>
    /*
      Rayline Audio global theme loader.
      Create this file in your GitHub data repo:
      https://raw.githubusercontent.com/dgraygoza16-gif/rayline-audio-data/refs/heads/main/site-theme.json

      Change colors/fonts/radius/shadows in site-theme.json, and every page that includes
      this loader can update without manually editing each section.
    */
    const raSiteThemeUrl = "https://raw.githubusercontent.com/dgraygoza16-gif/rayline-audio-data/refs/heads/main/site-theme.json";

    function raSetThemeVar(name, value) {
      if (value === undefined || value === null || value === "") return;
      document.documentElement.style.setProperty(name, value);
    }

    function raApplySiteTheme(theme) {
      if (!theme) return;

      const brand = theme.brand || {};
      const colors = theme.colors || {};
      const borders = theme.borders || {};
      const shadows = theme.shadows || {};
      const radius = theme.radius || {};
      const buttons = theme.buttons || {};
      const cards = theme.cards || {};
      const effects = theme.effects || {};

      raSetThemeVar("--ra-font-primary", brand.fontPrimary);
      raSetThemeVar("--ra-font-display", brand.fontDisplay);

      raSetThemeVar("--ra-purple", colors.primary);
      raSetThemeVar("--ra-purple-dark", colors.primaryDark);
      raSetThemeVar("--ra-purple-soft", colors.primarySoft);
      raSetThemeVar("--ra-accent", colors.accent);
      raSetThemeVar("--ra-black", colors.black);
      raSetThemeVar("--ra-text", colors.body);
      raSetThemeVar("--ra-muted", colors.muted);
      raSetThemeVar("--ra-white", colors.white);
      raSetThemeVar("--ra-page-soft", colors.pageSoft);
      raSetThemeVar("--ra-page-bg", colors.pageBg);

      raSetThemeVar("--ra-border", borders.default);
      raSetThemeVar("--ra-border-strong", borders.strong);
      raSetThemeVar("--ra-glass-border", borders.glass);

      raSetThemeVar("--ra-shadow", shadows.card);
      raSetThemeVar("--ra-shadow-soft", shadows.soft);
      raSetThemeVar("--ra-button-shadow", shadows.button);

      raSetThemeVar("--ra-radius-small", radius.small);
      raSetThemeVar("--ra-radius-medium", radius.medium);
      raSetThemeVar("--ra-radius-large", radius.large);
      raSetThemeVar("--ra-radius-xl", radius.xl);
      raSetThemeVar("--ra-radius-pill", radius.pill);

      raSetThemeVar("--ra-button-gradient", buttons.primaryGradient);
      raSetThemeVar("--ra-card-bg", cards.background);
      raSetThemeVar("--ra-card-border", cards.border);
      raSetThemeVar("--ra-card-shadow", cards.shadow);
      raSetThemeVar("--ra-card-radius", cards.radius);
      raSetThemeVar("--ra-player-gradient", effects.playerGradient);
      raSetThemeVar("--ra-hero-bg-glow", effects.heroGlow);
    }

    async function raLoadSiteTheme() {
      try {
        const response = await fetch(raSiteThemeUrl, { cache: "no-store" });
        if (!response.ok) throw new Error("Theme file not found");
        const theme = await response.json();
        raApplySiteTheme(theme);
        window.raSiteTheme = theme;
      } catch (error) {
        console.warn("Rayline Audio theme database could not be loaded. Using page fallback theme.", error);
      }
    }

    raLoadSiteTheme();
  </script>
